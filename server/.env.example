# Copy to server/.env. Same credentials as the spike (from api.metrolisboa.pt/store).
# Easiest: the pre-encoded Basic blob = base64(consumerKey:consumerSecret).
ML_BASIC_AUTH=

# Or the raw pair:
ML_CONSUMER_KEY=
ML_CONSUMER_SECRET=

# Optional tuning:
# ML_POLL_INTERVAL_SECONDS=12
# ML_STREAM_INTERVAL_SECONDS=1.5
# ML_INSECURE_TLS=true

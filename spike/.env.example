# Copy to spike/.env and fill in from https://api.metrolisboa.pt/store/

# Easiest: the pre-encoded Basic value straight from the store's curl snippet
# (the blob after "Authorization: Basic ..."). It is base64(consumerKey:consumerSecret).
ML_BASIC_AUTH=

# Or the raw pair instead of the encoded blob:
ML_CONSUMER_KEY=
ML_CONSUMER_SECRET=

# Or a ready-made token (expires ~1h — fine for quick tests, not long captures):
ML_ACCESS_TOKEN=
